<section class="stack">
  <header style="display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; align-items: end;">
    <div>
      <h2>Job <code><%= @job.id %></code></h2>
      <p>Detailed execution and payload view for a single Solid Queue job.</p>
    </div>

    <div class="cluster">
      <span class="status-pill"><%= @job.status.to_s.humanize %></span>
      <a href="<%= jobs_path(state: params[:state].presence || @job.status) %>">Back to jobs</a>
      <a href="<%= job_path(@job, format: :json) %>">JSON</a>
    </div>
  </header>

  <div class="metric-grid">
    <article class="panel metric-card">
      <span class="metric-label">Class</span>
      <strong><%= @job.class_name %></strong>
    </article>

    <article class="panel metric-card">
      <span class="metric-label">Queue</span>
      <strong><%= @job.queue_name %></strong>
    </article>

    <article class="panel metric-card">
      <span class="metric-label">Priority</span>
      <strong><%= @job.priority %></strong>
    </article>

    <article class="panel metric-card">
      <span class="metric-label">Active Job ID</span>
      <strong style="font-size: 1rem;"><%= @job.active_job_id %></strong>
    </article>
  </div>

  <article class="panel process-card">
    <h3>Timeline</h3>
    <table>
      <tbody>
        <tr>
          <th scope="row">Created</th>
          <td><%= @job.created_at %></td>
        </tr>
        <tr>
          <th scope="row">Scheduled</th>
          <td><%= @job.scheduled_at || "n/a" %></td>
        </tr>
        <tr>
          <th scope="row">Updated</th>
          <td><%= @job.updated_at %></td>
        </tr>
        <tr>
          <th scope="row">Finished</th>
          <td><%= @job.finished_at || "n/a" %></td>
        </tr>
        <tr>
          <th scope="row">Concurrency Key</th>
          <td><%= @job.concurrency_key || "n/a" %></td>
        </tr>
      </tbody>
    </table>
  </article>

  <% if @job.failed_execution.present? %>
    <article class="panel process-card">
      <h3>Failure</h3>
      <p><strong><%= @job.failed_execution.exception_class %></strong>: <%= @job.failed_execution.message %></p>
      <% if @job.failed_execution.backtrace.present? %>
        <pre><%= @job.failed_execution.backtrace.join("\n") %></pre>
      <% end %>
    </article>
  <% end %>

  <% if @job.recurring_execution.present? %>
    <article class="panel process-card">
      <h3>Recurring Context</h3>
      <table>
        <tbody>
          <tr>
            <th scope="row">Task Key</th>
            <td><%= @job.recurring_execution.task_key %></td>
          </tr>
          <tr>
            <th scope="row">Run At</th>
            <td><%= @job.recurring_execution.run_at %></td>
          </tr>
        </tbody>
      </table>
    </article>
  <% end %>

  <article class="panel process-card">
    <h3>Arguments</h3>
    <pre><%= JSON.pretty_generate(@job.arguments) %></pre>
  </article>
</section>