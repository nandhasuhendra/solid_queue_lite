<!DOCTYPE html>
<html>
<head>
  <title>Solid Queue Lite</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>

  <style>
    :root {
      --sq-primary: #4f46e5;
      --sq-success: #10b981;
      --sq-danger: #ef4444;
      --sq-warning: #f59e0b;
      --sq-ink: #111827;
      --sq-muted: #6b7280;
      --sq-panel: #ffffff;

      --pico-font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
      --pico-primary: var(--sq-primary);
      --pico-primary-background: var(--sq-primary);
      --pico-primary-border: var(--sq-primary);
      --pico-primary-hover: #4338ca;
      --pico-primary-hover-background: #4338ca;
      --pico-primary-hover-border: #4338ca;
      --pico-primary-focus: rgba(79, 70, 229, 0.25);
      --pico-border-radius: 0;
    }

    [x-cloak] {
      display: none !important;
    }

    body {
      min-height: 100vh;
      color: var(--sq-ink);
    }

    header.container {
      padding-top: 2rem;
      padding-bottom: 1rem;
    }

    main.container {
      padding-bottom: 3rem;
    }

    article {
      box-shadow: none !important;
      border: 1px solid var(--pico-muted-border-color);
      border-radius: 0 !important;
      background: var(--sq-panel);
    }

    .panel {
      border: 1px solid var(--pico-muted-border-color);
      background: var(--sq-panel);
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.3rem 0.6rem;
      font-size: 0.8rem;
      font-weight: 700;
      background: rgba(79, 70, 229, 0.08);
      color: var(--sq-primary);
      border: 1px solid rgba(79, 70, 229, 0.2);
    }

    .status-dot {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      margin-right: 0.4rem;
    }

    .status-active {
      background-color: var(--sq-success);
    }

    .status-stale,
    .status-warning {
      background-color: var(--sq-warning);
    }

    .status-dead {
      background-color: var(--sq-danger);
    }

    .filter-nav {
      margin-top: 1rem;
      margin-bottom: 2rem;
      border-bottom: 1px solid var(--pico-muted-border-color);
    }

    .filter-nav a {
      cursor: pointer;
      padding: 0.5rem 1rem;
      display: inline-block;
      border-bottom: 2px solid transparent;
      color: var(--sq-muted);
      text-decoration: none;
    }

    .filter-nav a.active {
      border-bottom-color: var(--sq-primary);
      color: var(--sq-ink);
      font-weight: 700;
    }

    .toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }

    .metric-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    }

    .metric-label,
    .process-meta,
    .queue-meta,
    .muted {
      color: var(--sq-muted);
      font-size: 0.92rem;
    }

    .cluster {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
    }

    .stack {
      display: grid;
      gap: 1rem;
    }

    .ct-series-a .ct-line,
    .ct-series-a .ct-point {
      stroke: var(--sq-primary);
    }

    .ct-series-a .ct-area {
      fill: rgba(79, 70, 229, 0.12);
    }

    .ct-series-b .ct-line,
    .ct-series-b .ct-point {
      stroke: var(--sq-danger);
    }

    .ct-chart {
      height: 220px;
      margin-top: 1rem;
    }

    .job-row {
      cursor: pointer;
      transition: background-color 0.1s ease;
    }

    .job-row:hover {
      background-color: rgba(128, 128, 128, 0.05);
    }

    .chevron {
      transition: transform 0.2s ease;
      display: inline-block;
      width: 16px;
      height: 16px;
      vertical-align: text-bottom;
      margin-right: 4px;
    }

    .chevron.expanded {
      transform: rotate(90deg);
    }

    .job-detail-row td {
      padding: 0;
      border-bottom: none;
    }

    .job-detail-content {
      padding: 1.5rem;
      background: rgba(128, 128, 128, 0.02);
      border-left: 3px solid var(--sq-primary);
      margin: 0 0 1rem;
      box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.02);
    }

    .job-detail-content pre,
    .process-card pre,
    .code-block {
      margin: 0;
      padding: 1rem;
      background: var(--pico-code-background-color);
      border: 1px solid var(--pico-muted-border-color);
      font-size: 0.85rem;
      overflow-x: auto;
    }

    .actions-col {
      display: flex;
      gap: 0.5rem;
    }

    .actions-col button {
      padding: 0.25rem 0.5rem;
      font-size: 0.8rem;
      margin: 0;
      width: auto;
    }

    .process-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.5rem;
    }

    .process-card {
      margin-bottom: 0;
      display: flex;
      flex-direction: column;
    }

    .process-card header {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--pico-muted-border-color);
      background: rgba(128, 128, 128, 0.02);
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0;
    }

    .process-card ul {
      margin: 0;
      padding: 1rem;
      list-style: none;
      font-size: 0.9rem;
      flex-grow: 1;
    }

    .process-card ul li {
      margin-bottom: 0.5rem;
      display: flex;
      justify-content: space-between;
    }

    .process-card footer {
      padding: 0.75rem 1rem;
      border-top: 1px solid var(--pico-muted-border-color);
      background: rgba(128, 128, 128, 0.02);
      margin-top: 0;
    }

    .queue-badge {
      font-size: 0.75rem;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      background: var(--pico-secondary-background);
      color: var(--pico-secondary-inverse);
      text-decoration: none;
      display: inline-block;
      margin: 0.1rem 0.2rem 0.1rem 0;
      border: 1px solid var(--pico-secondary-border);
      transition: filter 0.1s ease;
    }

    .queue-badge:hover {
      filter: brightness(1.1);
      color: var(--pico-secondary-inverse);
    }

    .empty-state {
      padding: 2rem 1rem;
      text-align: center;
      color: var(--sq-muted);
      background: var(--sq-panel);
      border: 1px solid var(--pico-muted-border-color);
    }

    @media (max-width: 768px) {
      .toolbar {
        flex-direction: column;
        align-items: stretch;
      }

      .filter-nav a {
        padding-left: 0.5rem;
        padding-right: 0.5rem;
      }
    }
  </style>

  <script>
    document.addEventListener("alpine:init", () => {
      Alpine.store("dashboard", {
        autoRefresh: 0,
        interval: null,
        paused: false,
        init() {
          const storedValue = Number(window.sessionStorage.getItem("solid-queue-dashboard-lite:auto-refresh") || 0);
          this.setAutoRefresh(storedValue);
        },
        setAutoRefresh(seconds) {
          this.autoRefresh = Number(seconds || 0);
          window.sessionStorage.setItem("solid-queue-dashboard-lite:auto-refresh", this.autoRefresh);

          if (this.interval) {
            window.clearInterval(this.interval);
            this.interval = null;
          }

          if (this.autoRefresh > 0) {
            this.interval = window.setInterval(() => {
              if (!this.paused && !document.hidden) {
                window.location.reload();
              }
            }, this.autoRefresh * 1000);
          }
        },
        setPaused(value) {
          this.paused = Boolean(value);
        }
      });
    });
  </script>

  <%= yield :head %>
</head>
<body x-data="{ autoRefresh: 0 }"
      x-init="autoRefresh = $store.dashboard.autoRefresh; $store.dashboard.init(); autoRefresh = $store.dashboard.autoRefresh"
      x-on:dashboard-pause.window="$store.dashboard.setPaused($event.detail.paused)">
<header class="container">
  <nav>
    <ul>
      <li>
        <hgroup>
          <h1>Solid Queue</h1>
          <p>Production Telemetry &amp; Operations</p>
        </hgroup>
      </li>
    </ul>
    <ul>
      <li>
        <select x-model="autoRefresh" @change="$store.dashboard.setAutoRefresh(Number(autoRefresh))" aria-label="Auto-refresh" style="width: auto; padding-right: 2rem;">
          <option value="0">Auto-Refresh: Off</option>
          <option value="5">Refresh: 5s</option>
          <option value="10">Refresh: 10s</option>
          <option value="30">Refresh: 30s</option>
        </select>
      </li>
    </ul>
  </nav>
</header>

<main class="container">
  <% if notice.present? %>
    <p><mark><%= notice %></mark></p>
  <% end %>
  <% if alert.present? %>
    <p><mark><%= alert %></mark></p>
  <% end %>

  <%= yield %>
</main>
</body>
</html>
